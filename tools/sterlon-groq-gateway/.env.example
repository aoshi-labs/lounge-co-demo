# Copy to .env in this directory (never commit .env).

# Groq cloud key. In production, store this as a deployment secret.
GROQ_API_KEY=

# Optional bind host and port.
PORT=8787
HOST=127.0.0.1

# Production model for Sterlon prose (browser sends sterlon-demo → this id).
# openai/gpt-oss-120b = Groq flagship 120B production model.
# Fallback: llama-3.3-70b-versatile
# https://console.groq.com/docs/models
GROQ_MODEL=openai/gpt-oss-120b

# Retry attempts on 429/502/503 (default 3, max 5).
GROQ_MAX_RETRIES=3

# Minimum ms between outgoing Groq calls; helps avoid back-to-back 429s during testing.
GROQ_REQUEST_INTERVAL_MS=1200

# Local/offline verification only. Leave false for real demos.
GROQ_MOCK=false
